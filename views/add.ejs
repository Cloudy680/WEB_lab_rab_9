<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Зоопарк</h1>
            <p>Добавление нового животного</p>
        </div>
        
        <div class="nav">
            <a href="/">Главная</a>
            <a href="/add">Добавить животное</a>
            <a href="/game" class="btn-game">🎮 Игра "Словарная цепочка"</a>
        </div>
        
        <div class="content">
            <div class="form-container">
                <h2>Добавить животное</h2>
                
                <form method="POST" action="/add">
                    <div class="form-group">
                        <label for="name">Название животного:</label>
                        <input type="text" 
                               id="name" 
                               name="name" 
                               required 
                               placeholder="Например: Амурский тигр"
                               value="<%= typeof name !== 'undefined' ? name : '' %>">
                    </div>
                    
                    <div class="form-group">
                        <label for="care">Правила ухода:</label>
                        <textarea id="care" 
                                  name="care" 
                                  required 
                                  placeholder="Опишите правила ухода за животным..."><%= typeof care !== 'undefined' ? care : '' %></textarea>
                    </div>
                    
                    <div class="form-group">
                        <button type="submit" class="btn-save">Сохранить</button>
                        <a href="/" class="btn-cancel">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; 2024 Зоопарк. Все права защищены</p>
        </div>
    </div>
</body>
</html>