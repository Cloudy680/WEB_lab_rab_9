<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Зоопарк</h1>
            <p>Редактирование животного</p>
        </div>
        
        <div class="nav">
            <a href="/">Главная</a>
            <a href="/add">Добавить животное</a>
            <a href="/game" class="btn-game">🎮 Игра "Словарная цепочка"</a>
        </div>
        
        <div class="content">
            <div class="form-container">
                <h2>Редактировать: <%= animal.name %></h2>
                
                <form method="POST" action="/edit/<%= animal.id %>">
                    <div class="form-group">
                        <label for="name">Название животного:</label>
                        <input type="text" 
                               id="name" 
                               name="name" 
                               required 
                               value="<%= animal.name %>">
                    </div>
                    
                    <div class="form-group">
                        <label for="care">Правила ухода:</label>
                        <textarea id="care" 
                                  name="care" 
                                  required><%= animal.care %></textarea>
                    </div>
                    
                    <div class="form-group">
                        <button type="submit" class="btn-save">Обновить</button>
                        <a href="/view/<%= animal.id %>" class="btn-cancel">Отмена</a>
                        <button type="button" onclick="deleteAnimal(<%= animal.id %>, '<%= animal.name %>')" class="btn-delete">Удалить</button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; 2024 Зоопарк. Все права защищены</p>
        </div>
    </div>
    
    <script src="/js/app.js"></script>
</body>
</html>