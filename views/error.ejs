            <div class="error-message">
                <p><%= message %></p>
                <a href="/" class="btn-back">Вернуться на главную</a>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; 2024 Зоопарк. Все права защищены</p>
        </div>
    </div>
