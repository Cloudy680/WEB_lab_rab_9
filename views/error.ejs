<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="header error-header">
            <h1>Ошибка</h1>
            <p><%= title %></p>
        </div>
        
        <div class="nav">
            <a href="/">Главная</a>
            <a href="/add">Добавить животное</a>
            <a href="/game" class="btn-game">🎮 Игра "Словарная цепочка"</a>
