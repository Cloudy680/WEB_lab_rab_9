<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Зоопарк</h1>
            <p>Информация о животном</p>
        </div>
        
        <div class="nav">
            <a href="/">Главная</a>
            <a href="/add">Добавить животное</a>
            <a href="/game" class="btn-game">🎮 Игра "Словарная цепочка"</a>
        </div>
        
        <div class="content">
            <div class="detail-card">
                <div class="detail-header">
                    <h2><%= animal.name %></h2>
                    <div class="detail-id">ID: <%= animal.id %></div>
                </div>
                
                <div class="detail-section">
                    <h3>Правила ухода</h3>
                    <p><%= animal.care %></p>
                </div>
                
                <div class="detail-actions">
                    <a href="/edit/<%= animal.id %>" class="btn-edit">Редактировать</a>
                    <button onclick="deleteAnimal(<%= animal.id %>, '<%= animal.name %>')" class="btn-delete">Удалить</button>
                    <a href="/" class="btn-back">Назад к списку</a>
                </div>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; 2024 Зоопарк. Все права защищены</p>
        </div>
    </div>
    
    <script src="/js/app.js"></script>
</body>
</html>